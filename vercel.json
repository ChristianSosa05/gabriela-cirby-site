<!-- ══════════ WHY PAGE ══════════ -->
<div id="page-why" class="page">

  <div class="page-hero-sub" style="background:none">
    <div class="page-hero-sub-bg" style="background:
      linear-gradient(to top,rgba(92,61,30,0.88) 0%,rgba(92,61,30,0.25) 100%),
