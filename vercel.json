        <button onclick="showPage('blog')">Insights</button>
        <button onclick="showPage('home');setTimeout(()=>document.getElementById('contact-strip').scrollIntoView({behavior:'smooth'}),100)">Contact</button>
      </div>
      <small>© 2025 Gabriela Cirby · California</small>
    </footer>
    <div style="background:var(--brown);text-align:center;padding:10px 24px">
      <small style="font-size:0.72rem;color:rgba(255,255,255,0.5);letter-spacing:0.04em">Agent License #01905458</small>
    </div>
  </div>

  <!-- BLOG READ VIEW -->
  <div class="blog-read-view" id="blogReadView">
    <div style="max-width:800px;margin:0 auto">
      <button class="blog-read-back" onclick="closeBlogPost()">← Back to all articles</button>
      <div class="blog-read-hero" id="blogReadHero"></div>
      <div class="blog-read-inner">
        <p class="blog-read-meta" id="blogReadMeta"></p>
        <h1 id="blogReadTitle"></h1>
        <div class="blog-read-meta" id="blogReadMeta2"></div>
        <div class="blog-read-body" id="blogReadBody"></div>
      </div>
    </div>
  </div>

</div><!-- /page-blog -->

<script>
// ── PAGE ROUTING ──
function showPage(name){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  window.scrollTo(0,0);
  if(name==='blog'){
    document.getElementById('blog-list-view').style.display='block';
    document.getElementById('blogReadView').classList.remove('show');
    renderBlogs();
  }
}

// ── CONTACT FORM ──
function submitContact(e){
  e.preventDefault();
  document.getElementById('contactSuccess').classList.add('show');
  e.target.querySelector('button[type=submit]').disabled=true;
}

// ── BLOG POSTS — add new posts to the top of this array ──
const SEED_POSTS=[
  {
    id:'seed1',
    title:'What to Look For in a 55+ Community (Beyond the Brochure)',
    category:'Buyer\'s Guide',
    date:'June 15, 2025',
    excerpt:'The amenities photos are gorgeous. But what\'s the actual day-to-day like? Here\'s what Gabriela looks at that the brochure won\'t tell you.',
    body:`When clients first reach out, they usually come with a list of communities they found online. And honestly, the marketing for most of them is excellent — gleaming pools, smiling residents, beautifully staged homes.

But after helping hundreds of families find the right fit, I've learned that the things that make a community truly great almost never show up in a brochure.

Here's what I actually look at when I evaluate a 55+ community on your behalf.

The HOA financials. Before anything else, I request the HOA reserve study and recent meeting minutes. A community that looks beautiful today could be facing deferred maintenance, special assessments, or poor financial management. These documents reveal things no tour will show you.

The social calendar. A robust calendar of events isn't just nice to have — it's a window into the community's culture. Is it active and diverse? Do residents actually show up? I've visited communities where the calendar looks full but the clubhouse is empty.

Turnover and resale history. A community where homes sell quickly and prices hold steady is a community where residents are happy. Stale listings are a signal worth investigating.

The pulse of current residents. I always talk to people who actually live there — not the sales staff. I ask what they love, what surprised them, and what they'd tell a friend who was considering moving in.

If you're starting your search, I'd love to walk you through what I find. Reach out and let's have a conversation.`,
    image:'https://images.unsplash.com/photo-1560472354-b33ff0c44a43?w=800&q=80'
  },
  {
    id:'seed2',
    title:'The 5 Questions You Should Ask Before Buying in a 55+ Community',
    category:'Tips & Advice',
    date:'May 3, 2025',
    excerpt:'Most buyers walk away from a community tour with nice feelings and no real information. These five questions change that.',
    body:`A community tour is designed to make you feel good. The sales staff is warm, the amenities are sparkling, and the model home is immaculate. That's their job.

Your job is to ask the questions that pierce through the staging and get you to the truth.

Here are the five I recommend every buyer ask — and why each one matters.

1. What is the monthly HOA fee, and what exactly does it cover?
This seems obvious, but the answer varies enormously from community to community. Some HOAs include water, trash, cable, and exterior insurance. Others cover almost nothing beyond landscaping. Know precisely what you're paying for.

2. What are the reserves, and when was the last reserve study completed?
Underfunded reserves mean special assessments — unexpected bills that can run into the thousands. A well-funded reserve fund is a sign of responsible management.

3. What are the rules around guests and family members under 55?
Most communities allow younger residents under certain conditions, but the rules vary. If you have adult children or grandchildren who visit regularly, you need to understand the policy before you buy.

4. How active is the social life, really?
Ask to see the last three months of the activity calendar. Ask how many residents typically attend events. Better yet, come on a weekday and see for yourself.

5. What's the process if I want to rent out my home?
Many 55+ communities restrict rentals entirely, or allow them only under specific conditions. If you're considering this as an investment property, or if you travel extensively, this question is essential.

Ready to start touring communities? I'll be with you every step of the way — and I'll make sure we ask the right questions.`,
    image:'https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?w=800&q=80'
  },
  {
    id:'seed3',
    title:'Why California is One of the Best Places to Retire in the Country',
    category:'Market Insights',
    date:'March 20, 2025',
    excerpt:'Climate, community, coast, and quality of life — there\'s a reason people move to California from all over the country. Here\'s the honest picture.',
    body:`I may be biased — I've spent my career here — but California consistently earns its reputation as one of the best places in the country to retire.

Here's what actually drives that ranking.

The climate is genuinely exceptional. From the mild coastal air of the Central Coast to the warm, sun-drenched valleys of Southern California and the crisp mountain communities of the Sierra foothills, California offers a climate for every preference — with more than 280 sunny days per year across most of the state.

The 55+ community landscape is the most diverse in the nation. Whether you're drawn to golf-course resort communities in the Coachella Valley, peaceful wine-country villages in Temecula, or established active adult neighborhoods throughout the Bay Area and Sacramento region, California has options at every price point and lifestyle.

Healthcare infrastructure is world-class statewide. From UCLA and UCSF to Cedars-Sinai and Stanford Health Care, California is home to some of the most respected medical institutions in the world — a factor that matters more than people realize when choosing where to retire.

The natural beauty is unmatched. Mountains, desert, coast, and valley — often within an hour's drive of each other. The ability to hike in the morning and walk a beach in the afternoon is a quality of life that's simply hard to find anywhere else.

If you're considering a move to California and want an honest picture of which communities might fit your life, I'd love to talk.`,
    image:'https://images.unsplash.com/photo-1513407030348-c983a97b98d8?w=800&q=80'
  }
];

function renderBlogs(){
  const grid=document.getElementById('blogGrid');
  if(!SEED_POSTS.length){
    grid.innerHTML=`<div class="blog-empty"><p>No posts yet.</p></div>`;
    return;
  }
  grid.innerHTML=SEED_POSTS.map(p=>`
    <div class="blog-card" onclick="openPost('${p.id}')">
      <div class="blog-thumb" style="background-image:url('${p.image||''}');background-color:var(--sky-light)">
        <span class="blog-tag">${p.category||'Article'}</span>
      </div>
      <div class="blog-body">
        <div class="blog-date">${p.date}</div>
        <h3>${p.title}</h3>
        <p class="blog-excerpt">${p.excerpt||''}</p>
        <button class="blog-read" onclick="event.stopPropagation();openPost('${p.id}')">Read article <span>→</span></button>
      </div>
    </div>
  `).join('');
}

function openPost(id){
  const post=SEED_POSTS.find(p=>p.id===id);
  if(!post)return;
  document.getElementById('blogReadHero').style.backgroundImage=post.image?`url('${post.image}')`:'';
  document.getElementById('blogReadTitle').textContent=post.title;
  document.getElementById('blogReadMeta').textContent=`${post.category} · ${post.date}`;
  document.getElementById('blogReadMeta2').textContent='';
  const bodyEl=document.getElementById('blogReadBody');
  bodyEl.innerHTML=post.body.split(/\n\n+/).map(para=>`<p>${para.trim()}</p>`).join('');
  document.getElementById('blog-list-view').style.display='none';
  document.getElementById('blogReadView').classList.add('show');
  window.scrollTo(0,0);
}

function closeBlogPost(){
  document.getElementById('blogReadView').classList.remove('show');
  document.getElementById('blog-list-view').style.display='block';
  window.scrollTo(0,0);
}

// Init
renderBlogs();
</script>
</body>
</html>
