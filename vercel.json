<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Gabriela Cirby | 55+ Community Real Estate Specialist | California</title>
<meta name="description" content="Gabriela Cirby is a California real estate agent specializing in 55+ active adult communities. Expert guidance for retirement home buyers across Southern California, the Coachella Valley, Orange County, and beyond."/>
<meta name="keywords" content="55+ communities California, active adult communities Southern California, retirement homes California, 55 plus real estate agent, Gabriela Cirby, 55+ specialist California, active adult real estate, senior communities California"/>
<meta name="author" content="Gabriela Cirby"/>
<meta property="og:title" content="Gabriela Cirby | 55+ Community Specialist | California"/>
<meta property="og:description" content="Find your perfect 55+ active adult community in California with expert guidance from Gabriela Cirby, a trusted real estate specialist since 2011."/>
<meta property="og:type" content="website"/>
<meta name="robots" content="index, follow"/>
<link rel="canonical" href="https://gabrielacirby.com/"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --sky:#6BA3C8;
  --sky-light:#A8CCE5;
  --sky-dark:#3E6E96;
  --gold:#C4973F;
  --gold-light:#E8D5AA;
  --brown:#5C3D1E;
  --parchment:#F6F0E6;
  --parchment-dark:#EDE3D0;
  --white:#FFFFFF;
  --ink:#2C2118;
  --muted:#7A6A52;
  --font-display:'Playfair Display',Georgia,serif;
  --font-body:'Lato',system-ui,sans-serif;
}
html{scroll-behavior:smooth}
body{font-family:var(--font-body);background:var(--parchment);color:var(--ink);font-weight:300;line-height:1.7;overflow-x:hidden}

/* ── PAGE SYSTEM ── */
.page{display:none;min-height:100vh}
.page.active{display:block}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  background:rgba(246,240,230,0.96);
  backdrop-filter:blur(10px);
  border-bottom:2px solid var(--gold-light);
  padding:0 48px;
  height:68px;
  display:flex;align-items:center;justify-content:space-between;
}
.nav-brand{
  display:flex;align-items:center;gap:12px;
  text-decoration:none;
  cursor:pointer;
}
.nav-monogram{
  width:42px;height:42px;
  background:var(--sky);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--font-display);
  font-size:1.1rem;font-weight:700;
  color:var(--white);
  letter-spacing:-0.02em;
  flex-shrink:0;
}
.nav-name{
  font-family:var(--font-display);
  font-size:1.05rem;font-weight:600;
  color:var(--brown);
  line-height:1.1;
}
.nav-name small{
  display:block;
  font-family:var(--font-body);
  font-size:0.62rem;font-weight:400;
  letter-spacing:0.14em;text-transform:uppercase;
  color:var(--muted);
}
.nav-links{display:flex;align-items:center;gap:8px;list-style:none}
.nav-links a,.nav-links button{
  font-size:0.78rem;font-weight:700;
  letter-spacing:0.1em;text-transform:uppercase;
  color:var(--brown);
  background:none;border:none;cursor:pointer;
  padding:8px 14px;
  text-decoration:none;
  transition:color 0.2s;
  font-family:var(--font-body);
}
.nav-links a:hover,.nav-links button:hover{color:var(--sky-dark)}
.nav-links .nav-cta{
  background:var(--sky);color:var(--white);
  padding:9px 20px;
  transition:background 0.2s;
}
.nav-links .nav-cta:hover{background:var(--sky-dark)}

/* ── HERO ── */
.hero{
  position:relative;min-height:100vh;
  display:flex;align-items:center;
  overflow:hidden;padding-top:68px;
}
.hero-bg{
  position:absolute;inset:0;
  background:
    linear-gradient(to right, rgba(92,61,30,0.72) 0%, rgba(92,61,30,0.35) 55%, rgba(107,163,200,0.15) 100%),
    url('https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1600&q=80') center/cover no-repeat;
}
.hero-content{
  position:relative;z-index:2;
  max-width:640px;padding:80px 48px;
}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:10px;
  font-size:0.7rem;font-weight:700;
  letter-spacing:0.2em;text-transform:uppercase;
  color:var(--gold-light);margin-bottom:22px;
}
.hero-eyebrow span{
  display:inline-block;width:32px;height:1px;background:var(--gold);
}
.hero-h1{
  font-family:var(--font-display);
  font-size:clamp(2.4rem,5vw,4rem);
  font-weight:700;line-height:1.08;
  color:var(--white);margin-bottom:22px;
}
.hero-h1 em{font-style:italic;color:var(--sky-light)}
.hero-sub{
  font-size:1rem;color:rgba(255,255,255,0.85);
  max-width:480px;margin-bottom:40px;line-height:1.8;
}
.btn-gold{
  display:inline-block;padding:14px 36px;
  background:var(--gold);color:var(--white);
  font-size:0.78rem;font-weight:700;
  letter-spacing:0.12em;text-transform:uppercase;
  text-decoration:none;border:none;cursor:pointer;
  font-family:var(--font-body);
  transition:background 0.2s,transform 0.15s;
}
.btn-gold:hover{background:#a67c30;transform:translateY(-1px)}
.btn-sky{
  display:inline-block;padding:14px 36px;
  background:var(--sky);color:var(--white);
  font-size:0.78rem;font-weight:700;
  letter-spacing:0.12em;text-transform:uppercase;
  text-decoration:none;border:none;cursor:pointer;
  font-family:var(--font-body);
  transition:background 0.2s;
}
.btn-sky:hover{background:var(--sky-dark)}
.btn-outline-white{
  display:inline-block;padding:13px 34px;
  border:2px solid rgba(255,255,255,0.6);
  color:var(--white);
  font-size:0.78rem;font-weight:700;
  letter-spacing:0.12em;text-transform:uppercase;
  text-decoration:none;cursor:pointer;
  background:none;font-family:var(--font-body);
  transition:border-color 0.2s,background 0.2s;
  margin-left:14px;
}
.btn-outline-white:hover{border-color:var(--white);background:rgba(255,255,255,0.1)}
.hero-scroll-hint{
  position:absolute;bottom:32px;left:50%;transform:translateX(-50%);
  color:rgba(255,255,255,0.55);
  font-size:0.68rem;letter-spacing:0.16em;text-transform:uppercase;
  display:flex;flex-direction:column;align-items:center;gap:8px;
}
.scroll-arrow{
  width:1px;height:40px;background:rgba(255,255,255,0.3);
  position:relative;
  animation:scrollpulse 2s ease-in-out infinite;
}
@keyframes scrollpulse{0%,100%{opacity:0.3}50%{opacity:1}}

/* ── DIAGONAL BAND ── */
.diagonal-band{
  position:relative;background:var(--sky);
  padding:64px 80px;color:var(--white);
  clip-path:polygon(0 0,100% 8%,100% 100%,0 92%);
  margin:-2px 0;
}
.band-inner{
  max-width:1100px;margin:0 auto;
  display:grid;grid-template-columns:1fr 1fr 1fr;
  gap:48px;padding:20px 0;
}
.band-stat{text-align:center}
.band-num{
  font-family:var(--font-display);
  font-size:3rem;font-weight:700;
  color:var(--white);line-height:1;
  margin-bottom:6px;
}
.band-label{
  font-size:0.72rem;letter-spacing:0.14em;
  text-transform:uppercase;
  color:rgba(255,255,255,0.75);
}

/* ── WHAT IS 55+ ── */
.what-section{
  background:var(--parchment);
  padding:100px 80px;
}
.section-header{margin-bottom:56px}
.section-eyebrow{
  font-size:0.68rem;font-weight:700;
  letter-spacing:0.2em;text-transform:uppercase;
  color:var(--gold);margin-bottom:12px;
}
.section-title{
  font-family:var(--font-display);
  font-size:clamp(1.8rem,3.5vw,2.8rem);
  font-weight:600;line-height:1.15;color:var(--brown);
}
.section-title em{font-style:italic;color:var(--sky-dark)}
.section-rule{
  width:56px;height:3px;
  background:var(--gold);margin-top:18px;
}
.what-grid{
  display:grid;grid-template-columns:1fr 1fr;
  gap:2px;max-width:1100px;
}
.what-card{
  background:var(--white);padding:44px 40px;
  border-left:4px solid transparent;
  transition:border-color 0.2s;
}
.what-card:hover{border-left-color:var(--sky)}
.what-card-icon{
  font-size:2rem;margin-bottom:18px;
}
.what-card h3{
  font-family:var(--font-display);
  font-size:1.2rem;font-weight:600;
  color:var(--brown);margin-bottom:10px;
}
.what-card p{font-size:0.88rem;color:var(--muted);line-height:1.8}
.what-intro-col{
  display:grid;grid-template-columns:1.1fr 0.9fr;
  gap:64px;align-items:start;max-width:1100px;margin-bottom:56px;
}
.what-intro-col p{font-size:0.95rem;color:var(--muted);line-height:1.85;margin-bottom:16px}
.what-photo{
  background:var(--sky-light);
  aspect-ratio:4/3;
  background:url('https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=900&q=80') center/cover;
  position:relative;
}
.what-photo-caption{
  position:absolute;bottom:0;left:0;right:0;
  background:rgba(92,61,30,0.75);
  color:rgba(255,255,255,0.85);
  font-size:0.68rem;letter-spacing:0.1em;text-transform:uppercase;
  padding:10px 16px;
}

/* ── CONTACT STRIP ── */
.contact-strip{
  background:var(--brown);
  padding:80px 80px;
  display:grid;grid-template-columns:1fr 1fr;
  gap:80px;align-items:center;
  max-width:100%;
}
.strip-text h2{
  font-family:var(--font-display);
  font-size:2rem;font-weight:700;
  color:var(--white);margin-bottom:14px;
}
.strip-text p{color:rgba(255,255,255,0.75);font-size:0.92rem;line-height:1.8}
.contact-form-mini{display:flex;flex-direction:column;gap:14px}
.form-row-2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.form-field input,.form-field select,.form-field textarea{
  width:100%;padding:12px 16px;
  background:rgba(255,255,255,0.1);
  border:1px solid rgba(255,255,255,0.25);
  color:var(--white);
  font-family:var(--font-body);font-size:0.88rem;font-weight:300;
  outline:none;
  transition:border-color 0.2s;
}
.form-field input::placeholder,.form-field textarea::placeholder{color:rgba(255,255,255,0.45)}
.form-field input:focus,.form-field select:focus,.form-field textarea:focus{border-color:var(--gold)}
.form-field select option{background:var(--brown);color:var(--white)}
.form-field textarea{resize:vertical;min-height:90px}
.form-success{
  display:none;padding:24px;
  background:rgba(196,151,63,0.2);
  border:1px solid var(--gold);
  color:var(--white);
  font-family:var(--font-display);font-style:italic;font-size:1.1rem;
  text-align:center;
}
.form-success.show{display:block}

/* ── FOOTER ── */
footer{
  background:var(--ink);
  padding:40px 80px;
  display:flex;justify-content:space-between;align-items:center;
  flex-wrap:wrap;gap:16px;
}
.footer-brand{
  font-family:var(--font-display);
  font-size:1rem;font-weight:600;font-style:italic;
  color:var(--gold-light);
}
.footer-links{display:flex;gap:24px;flex-wrap:wrap}
.footer-links button{
  background:none;border:none;cursor:pointer;
  font-family:var(--font-body);font-size:0.72rem;
  letter-spacing:0.1em;text-transform:uppercase;
  color:rgba(255,255,255,0.5);
  transition:color 0.2s;
}
.footer-links button:hover{color:var(--gold)}
footer small{font-size:0.68rem;color:rgba(255,255,255,0.3);letter-spacing:0.04em}

/* ── WHY PAGE ── */
.page-hero-sub{
  height:55vh;min-height:360px;
  position:relative;display:flex;align-items:flex-end;
  padding-top:68px;
}
.page-hero-sub-bg{
  position:absolute;inset:0;
  background:
    linear-gradient(to top,rgba(92,61,30,0.85) 0%,rgba(92,61,30,0.2) 100%),
    url('https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=1400&q=80') center/cover;
}
.page-hero-sub-content{
  position:relative;z-index:2;
  padding:48px 80px;
}
.page-hero-sub-content h1{
  font-family:var(--font-display);
  font-size:clamp(2rem,4vw,3.2rem);
  font-weight:700;color:var(--white);
  margin-bottom:10px;
}
.page-hero-sub-content p{
  color:rgba(255,255,255,0.78);
  font-size:1rem;max-width:560px;
}
.why-section{padding:100px 80px;background:var(--parchment)}
.why-reasons{
  display:grid;grid-template-columns:1fr 1fr;
  gap:2px;margin-top:0;
}
.why-card{
  background:var(--white);padding:48px 44px;
  position:relative;overflow:hidden;
}
.why-card::before{
  content:'';position:absolute;top:0;left:0;
  width:4px;height:100%;
  background:var(--gold);
}
.why-number{
  font-family:var(--font-display);
  font-size:4rem;font-weight:700;
  color:var(--parchment-dark);
  position:absolute;top:12px;right:24px;
  line-height:1;
  user-select:none;
}
.why-card h3{
  font-family:var(--font-display);
  font-size:1.25rem;font-weight:600;
  color:var(--brown);margin-bottom:12px;
}
.why-card p{font-size:0.88rem;color:var(--muted);line-height:1.85}
.why-cta-block{
  background:var(--sky);padding:72px 80px;
  text-align:center;
}
.why-cta-block h2{
  font-family:var(--font-display);
  font-size:2.2rem;font-weight:700;font-style:italic;
  color:var(--white);margin-bottom:14px;
}
.why-cta-block p{color:rgba(255,255,255,0.8);margin-bottom:32px;font-size:0.95rem}

/* ── BLOG PAGE ── */
.blog-section{padding:60px 80px 100px;background:var(--parchment)}
.blog-top{
  display:flex;justify-content:space-between;
  align-items:flex-end;margin-bottom:48px;
}
.blog-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:28px;
}
.blog-card{
  background:var(--white);
  display:flex;flex-direction:column;
  cursor:pointer;
  transition:transform 0.2s;
}
.blog-card:hover{transform:translateY(-4px)}
.blog-thumb{
  height:200px;
  background:var(--sky-light) center/cover no-repeat;
  position:relative;
}
.blog-tag{
  position:absolute;bottom:12px;left:12px;
  background:var(--gold);
  color:var(--white);
  font-size:0.62rem;font-weight:700;
  letter-spacing:0.12em;text-transform:uppercase;
  padding:4px 10px;
}
.blog-body{padding:28px 28px 24px;flex:1;display:flex;flex-direction:column}
.blog-date{
  font-size:0.68rem;color:var(--muted);
  letter-spacing:0.08em;text-transform:uppercase;
  margin-bottom:10px;
}
.blog-card h3{
  font-family:var(--font-display);
  font-size:1.1rem;font-weight:600;
  color:var(--brown);line-height:1.35;
  margin-bottom:10px;flex:1;
}
.blog-excerpt{font-size:0.83rem;color:var(--muted);line-height:1.7;margin-bottom:16px}
.blog-read{
  font-size:0.72rem;font-weight:700;
  letter-spacing:0.1em;text-transform:uppercase;
  color:var(--sky-dark);
  display:flex;align-items:center;gap:6px;
  cursor:pointer;background:none;border:none;
  font-family:var(--font-body);padding:0;
  transition:gap 0.2s;
}
.blog-read:hover{gap:10px}
.blog-empty{
  grid-column:1/-1;text-align:center;
  padding:80px 40px;color:var(--muted);
}
.blog-empty p{font-size:0.95rem;margin-bottom:24px}

/* ── BLOG UPLOAD MODAL ── */
.modal-overlay{
  display:none;position:fixed;inset:0;
  background:rgba(44,33,24,0.7);
  z-index:1000;
  align-items:center;justify-content:center;
}
.modal-overlay.open{display:flex}
.modal-box{
  background:var(--white);
  width:min(680px,95vw);
  max-height:90vh;overflow-y:auto;
  padding:48px;position:relative;
}
.modal-close{
  position:absolute;top:16px;right:20px;
  background:none;border:none;cursor:pointer;
  font-size:1.4rem;color:var(--muted);
  transition:color 0.2s;
}
.modal-close:hover{color:var(--brown)}
.modal-title{
  font-family:var(--font-display);
  font-size:1.6rem;font-weight:600;
  color:var(--brown);margin-bottom:28px;
}
.modal-field{margin-bottom:18px;display:flex;flex-direction:column;gap:6px}
.modal-field label{
  font-size:0.72rem;font-weight:700;
  letter-spacing:0.1em;text-transform:uppercase;color:var(--ink);
}
.modal-field input,.modal-field select,.modal-field textarea{
  padding:11px 14px;
  border:1px solid var(--parchment-dark);
  background:var(--parchment);
  font-family:var(--font-body);font-size:0.9rem;font-weight:300;
  color:var(--ink);outline:none;
  transition:border-color 0.2s;
}
.modal-field input:focus,.modal-field select:focus,.modal-field textarea:focus{
  border-color:var(--sky);background:var(--white);
}
.modal-field textarea{min-height:200px;resize:vertical}
.modal-row2{display:grid;grid-template-columns:1fr 1fr;gap:16px}

/* ── BLOG READ VIEW ── */
.blog-read-view{
  display:none;padding:100px 80px 100px;
  background:var(--parchment);min-height:100vh;
}
.blog-read-view.show{display:block}
.blog-read-back{
  background:none;border:none;cursor:pointer;
  font-family:var(--font-body);
  font-size:0.75rem;font-weight:700;
  letter-spacing:0.12em;text-transform:uppercase;
  color:var(--sky-dark);display:flex;align-items:center;gap:8px;
  margin-bottom:40px;padding:0;
  transition:gap 0.2s;
}
.blog-read-back:hover{gap:12px}
.blog-read-hero{
  height:380px;
  background:var(--sky-light) center/cover no-repeat;
  margin-bottom:48px;
}
.blog-read-inner{max-width:720px;margin:0 auto}
.blog-read-inner h1{
  font-family:var(--font-display);
  font-size:clamp(1.8rem,3.5vw,2.8rem);
  font-weight:700;color:var(--brown);
  line-height:1.15;margin-bottom:16px;
}
.blog-read-meta{
  font-size:0.72rem;color:var(--muted);
  letter-spacing:0.08em;text-transform:uppercase;
  margin-bottom:32px;padding-bottom:32px;
  border-bottom:1px solid var(--parchment-dark);
}
.blog-read-body{font-size:0.95rem;line-height:1.9;color:var(--ink)}
.blog-read-body p{margin-bottom:20px}

/* ── CALENDLY ── */
.calendly-section{
  background:var(--parchment);
  padding:80px 80px;
  text-align:center;
}
.calendly-section h2{
  font-family:var(--font-display);
  font-size:clamp(1.6rem,3vw,2.4rem);
  font-weight:600;color:var(--brown);
  margin-bottom:10px;
}
.calendly-section p{
  font-size:0.92rem;color:var(--muted);
  margin-bottom:36px;max-width:500px;
  margin-left:auto;margin-right:auto;
}
.calendly-inline-widget{
  min-width:320px;height:700px;
  border:1px solid var(--border, #EDE3D0);
  max-width:900px;margin:0 auto;
}
@media(max-width:900px){
  .calendly-section{padding:60px 24px}
  .calendly-inline-widget{height:800px}
}

/* ── SOCIAL ICONS ── */
.social-links{display:flex;flex-direction:row;flex-wrap:wrap;gap:10px;margin-top:20px}
.social-link{
  display:flex;align-items:center;gap:8px;
  color:rgba(255,255,255,0.8);
  text-decoration:none;
  font-size:0.78rem;
  transition:color 0.2s;
}
.social-link:hover{color:var(--gold-light)}
.social-icon{
  width:40px;height:40px;
  border:1px solid rgba(255,255,255,0.25);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
  transition:border-color 0.2s,background 0.2s;
}
.social-link:hover .social-icon{border-color:var(--gold);background:rgba(196,151,63,0.2)}
.social-icon svg{width:18px;height:18px;fill:currentColor}
.social-label{display:none}

/* ── PHOTO CAPTION ── */
.photo-location{
  font-size:0.62rem;
  color:var(--muted);
  letter-spacing:0.06em;
  margin-top:6px;
  font-style:italic;
}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  nav{padding:0 20px}
  .nav-links li:not(:last-child){display:none}
  .hero-content{padding:60px 24px}
  .diagonal-band{padding:60px 24px;clip-path:none}
  .band-inner{grid-template-columns:1fr;gap:24px}
  .what-section,.why-section,.blog-section,.blog-read-view{padding:60px 24px}
  .what-intro-col{grid-template-columns:1fr;gap:32px}
